# Gotovo Frontend — environment variables
# Copy to .env.local and fill values for local dev.

# === Client (NEXT_PUBLIC_*) =====================================
# Base URL of the Gotovo backend /v1/* API.
# Local dev: probably http://localhost:8080/v1 (matches gotovo-backend default).
NEXT_PUBLIC_API_BASE_URL=https://gotovo-api.duckdns.org/v1

# Feature flag — full-text search input (Decision 0006).
# Stays `false` until the q parameter activates server-side
# (target: 2026-09-01 per Sunset header).
NEXT_PUBLIC_SEARCH_ENABLED=false

# Canonical site URL. Used by manifest, sitemap, robots, OG metadata.
NEXT_PUBLIC_SITE_URL=https://gotovo.app
